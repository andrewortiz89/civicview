# ── Servidor ────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Base de datos MySQL ──────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=civicview_db

# ── APIs externas ────────────────────────────
OPENWEATHER_API_KEY=tu_clave_openweathermap
AQICN_API_KEY=tu_clave_aqicn

# ── Cache (segundos) ─────────────────────────
CACHE_WEATHER_TTL=3600
CACHE_AIR_QUALITY_TTL=3600
CACHE_EVENTS_TTL=86400
CACHE_PICO_PLACA_TTL=86400
