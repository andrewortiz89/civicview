# ============================================================
# CivicView — .gitignore
# ============================================================

# ── Variables de entorno ───────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
backend/.env
frontend/.env

# ── Dependencias ─────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ── Build outputs ────────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/

# ── Caché de Vite ────────────────────────────────────────────
.vite/
frontend/.vite/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
backend/logs/

# ── Sistema operativo ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Editores ─────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Cobertura de tests ────────────────────────────────────────
coverage/
.nyc_output/

# ── Archivos temporales ───────────────────────────────────────
*.tmp
*.temp
.cache/