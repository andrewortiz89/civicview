# ══ CivicView — Variables de entorno ══════════════════════════
# Copia este archivo como .env y rellena tus claves de API


# ── Backend (si usas servidor propio) ─────────────────────────
VITE_BACKEND_URL=http://localhost:5000/api

# ── OpenWeatherMap ─────────────────────────────────────────────
# Obtén tu clave en: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=
VITE_OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── AQICN — Calidad del Aire ───────────────────────────────────
# Obtén tu clave en: https://aqicn.org/api/
VITE_AQICN_API_KEY=
VITE_AQICN_BASE_URL=https://api.waqi.info

# ── Notas ──────────────────────────────────────────────────────
# El módulo de Pico y Placa NO requiere API externa.
# La lógica es completamente local según la norma SDM 2026.